# OpenClaw
OPENCLAW_STATE_DIR=~/.clawdbot
OPENCLAW_BIN=node /path/to/.nvm/versions/node/v22.22.0/lib/node_modules/openclaw/dist/index.js

# Celo Network
NEXT_PUBLIC_CELO_RPC=https://alfajores-forno.celo-testnet.org
NEXT_PUBLIC_CHAIN_ID=44787

# ERC-8004 Contract (deploy your own or use existing on Alfajores)
NEXT_PUBLIC_ERC8004_CONTRACT_ADDRESS=

# WalletConnect (get from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mock mode (set to true for UI dev without OpenClaw)
NEXT_PUBLIC_MOCK_OPENCLAW=true

# Remote VPS gateway (Railway production)
# Set these when OpenClaw runs on a separate VPS
OPENCLAW_GATEWAY_URL=https://your-vps-ip-or-domain:3001
OPENCLAW_GATEWAY_TOKEN=your-shared-secret-token

# Railway / production overrides
# DATABASE_PATH=/data/agents.db
# OPENCLAW_STATE_DIR=/data/.clawdbot
