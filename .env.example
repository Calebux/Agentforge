# OpenClaw
OPENCLAW_STATE_DIR=~/.openclaw
OPENCLAW_BIN=node /path/to/openclaw/dist/index.js

# Celo Network
NEXT_PUBLIC_CELO_RPC=https://alfajores-forno.celo-testnet.org
NEXT_PUBLIC_CHAIN_ID=44787

# ERC-8004 Contract (deploy your own or use existing on Alfajores)
NEXT_PUBLIC_ERC8004_CONTRACT_ADDRESS=

# WalletConnect (get from cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mock mode (set to true for UI dev without OpenClaw)
NEXT_PUBLIC_MOCK_OPENCLAW=true
